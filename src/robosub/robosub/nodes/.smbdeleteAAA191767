#!/usr/bin/env python3
"""
ROS2 node for the submarine AI control stack.

Subscribes to sensor topics, assembles a SensorSuite each tick, runs the
Submarine mission plan, and publishes thruster commands. Responds to
/sim/control for pause/resume/reset/quit from the simulator node.

On hardware, replace simulator_node with a hardware_node publishing the
same topics — this node requires no changes.

Topics subscribed:
  /camera/image_raw    sensor_msgs/Image
  /sensors/depth       std_msgs/Float32
  /sensors/heading     std_msgs/Float32
  /sensors/pitch       std_msgs/Float32
  /sensors/imu         sensor_msgs/Imu
  /sensors/velocity    geometry_msgs/Twist
  /sim/control         std_msgs/String

Topics published:
  /thruster_commands   std_msgs/Float32MultiArray  ([hfl, hfr, hal, har, vf, vr])
  /sub/status          std_msgs/String             ("TaskName|state_name")
"""
from typing import Optional

import numpy as np

import rclpy
from rclpy.node import Node
from std_msgs.msg import Float32, Float32MultiArray, String
from sensor_msgs.msg import Image, Imu
from geometry_msgs.msg import Twist
from cv_bridge import CvBridge

from robosub.sub.submarine import Submarine
from robosub.sub.data_structures import SensorSuite, MPU6050Readings
from robosub.sub.tasks.stabilize_task import StabilizeTask
from robosub.sub.tasks.gate_task import GateTask
from robosub.sub.tasks.shutdown_task import ShutdownTask


def create_mission():
    return [
        StabilizeTask(target_depth=1.0),
        GateTask(target_depth=1.0),
        ShutdownTask(),
    ]


class SubmarineNode(Node):

    def __init__(self):
        super().__init__('submarine_node')

        self._bridge = CvBridge()
        self._sub    = Submarine(mission_plan=create_mission())
        self._paused = False

        # Latest sensor values — populated by callbacks before first tick
        self._camera_image: Optional[np.ndarray] = None
        self._depth:   float = 0.0
        self._heading: float = 0.0
        self._pitch:   float = 0.0
        self._imu            = MPU6050Readings()
        self._vel_x:   float = 0.0
        self._vel_y:   float = 0.0
        self._vel_z:   float = 0.0

        self.create_subscription(Image,            '/camera/image_raw', self._image_cb,   10)
        self.create_subscription(Float32,          '/sensors/depth',    self._depth_cb,   10)
        self.create_subscription(Float32,          '/sensors/heading',  self._heading_cb, 10)
        self.create_subscription(Float32,          '/sensors/pitch',    self._pitch_cb,   10)
        self.create_subscription(Imu,              '/sensors/imu',      self._imu_cb,     10)
        self.create_subscription(Twist,            '/sensors/velocity', self._vel_cb,     10)
        self.create_subscription(String,           '/sim/control',      self._ctrl_cb,    10)

        self._cmd_pub    = self.create_publisher(Float32MultiArray, '/thruster_commands', 10)
        self._status_pub = self.create_publisher(String,            '/sub/status',        10)

        self._last_stamp = self.get_clock().now()
        self.create_timer(1.0 / 60.0, self._control_loop)

    # --- Sensor callbacks ---

    def _image_cb(self, msg: Image):
        self._camera_image = self._bridge.imgmsg_to_cv2(msg, desired_encoding='bgr8')

    def _depth_cb(self, msg: Float32):
        self._depth = float(msg.data)

    def _heading_cb(self, msg: Float32):
        self._heading = float(msg.data)

    def _pitch_cb(self, msg: Float32):
        self._pitch = float(msg.data)

    def _imu_cb(self, msg: Imu):
        self._imu = MPU6050Readings(
            accel_x=float(msg.linear_acceleration.x),
            accel_y=float(msg.linear_acceleration.y),
            accel_z=float(msg.linear_acceleration.z),
            gyro_y=float(msg.angular_velocity.y),
            gyro_z=float(msg.angular_velocity.z),
        )

    def _vel_cb(self, msg: Twist):
        self._vel_x = float(msg.linear.x)
        self._vel_y = float(msg.linear.y)
        self._vel_z = float(msg.linear.z)

    def _ctrl_cb(self, msg: String):
        command = msg.data
        if command == 'pause':
            self._paused = True
        elif command == 'resume':
            self._paused = False
        elif command == 'reset':
            self._sub.reset()
            self._paused = False
        elif command == 'quit':
            self.get_logger().info('Received quit from simulator — shutting down.')
            rclpy.shutdown()

    # --- Control loop (60 Hz timer) ---

    def _control_loop(self):
        if self._paused or self._camera_image is None:
            return

        now = self.get_clock().now()
        dt  = (now - self._last_stamp).nanoseconds / 1e9
        self._last_stamp = now

        if dt <= 0.0 or dt > 0.1:
            return

        sensors = SensorSuite(
            camera_image=self._camera_image,
            depth=self._depth,
            heading=self._heading,
            pitch=self._pitch,
            imu=self._imu,
            velocity_x=self._vel_x,
            velocity_y=self._vel_y,
            velocity_z=self._vel_z,
        )

        commands, _ = self._sub.update(dt, sensors)

        status = String()
        status.data = f"{self._sub.get_current_task_name()}|{self._sub.get_current_state_name()}"
        self._status_pub.publish(status)

        out = Float32MultiArray()
        out.data = [
            float(commands.hfl), float(commands.hfr),
            float(commands.hal), float(commands.har),
            float(commands.vf),  float(commands.vr),
        ]
        self._cmd_pub.publish(out)


def main(args=None):
    rclpy.init(args=args)
    node = SubmarineNode()
    try:
        rclpy.spin(node)
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
